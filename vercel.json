{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/js/(.*)",
      "dest": "/frontend/js/$1"
    },
    {
      "src": "/(.*).html",
      "dest": "/frontend/$1.html"
    },
    {
      "src": "/style.css",
      "dest": "/frontend/style.css"
    },
    {
        "src": "/login",
        "dest": "/frontend/login.html"
    },
    {
        "src": "/register",
        "dest": "/frontend/register.html"
    },
    {
        "src": "/dashboard",
        "dest": "/frontend/dashboard.html"
    },
    {
        "src": "/transaction",
        "dest": "/frontend/transaction.html"
    },
    {
        "src": "/history",
        "dest": "/frontend/history.html"
    },
    {
        "src": "/profile",
        "dest": "/frontend/profile.html"
    },
    {
        "src": "/admin",
        "dest": "/frontend/admin_dashboard.html"
    },
    {
        "src": "/admin/users",
        "dest": "/frontend/admin_users.html"
    },
    {
        "src": "/admin/monitoring",
        "dest": "/frontend/admin_monitoring.html"
    },
    {
      "src": "/",
      "dest": "/frontend/index.html"
    }
  ]
}
